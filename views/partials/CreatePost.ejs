<div class="mb-8">
  <form action="/post" method="POST"
    class="flex items-center gap-4 bg-transparent rounded-[28px] p-4 shadow-xl backdrop-blur-xl">

    <img src="<%= user?.profile || '/profile/defaultProfile.png' %>" alt="profile"
      class="hidden sm:block w-14 h-14 rounded-2xl object-cover border border-zinc-700 shrink-0"/>

    <textarea name="content" required rows="1" placeholder="What's on your mind?"
      class="flex-1 bg-transparent border border-zinc-700 rounded-2xl px-5 py-4 resize-none outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all duration-300 text-[15px] placeholder:text-zinc-500 leading-6 min-h-[60px] max-h-[140px]"></textarea>

    <button
      class="px-6 sm:px-7 h-[60px] rounded-2xl bg-blue-600 hover:bg-blue-700 transition-all duration-300 font-semibold text-white shrink-0">
      Post
    </button>

  </form>
</div>