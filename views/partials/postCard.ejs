<!-- ========================= POST CARD ========================= -->
<div class="group relative w-full">

  <!-- Glow -->
  <div class="absolute inset-0 rounded-[30px] bg-gradient-to-r from-blue-500/10 via-indigo-500/5 to-pink-500/10 blur-2xl opacity-0 group-hover:opacity-100 transition duration-500"></div>

  <!-- CARD -->
  <div class="relative bg-transparent rounded-[28px] px-4 py-4 sm:px-5 sm:py-5 transition-all duration-300 backdrop-blur-xl">

    <div class="flex gap-3 sm:gap-4">

      <!-- PROFILE -->
      <a href="/user/<%= post.author._id %>" class="shrink-0">

        <img
          src="<%= post.author.profile || '/profile/defaultProfile.png' %>"
          alt="author"
          class="w-12 h-12 sm:w-14 sm:h-14 rounded-2xl object-cover border border-zinc-700 hover:border-blue-500 transition-all duration-300"
        />

      </a>





      <!-- RIGHT -->
      <div class="flex-1 min-w-0">

        <!-- TOP -->
        <div class="flex items-start justify-between gap-3">

          <!-- LEFT -->
          <div class="min-w-0">

            <a
              href="/user/<%= post.author._id %>"
              class="text-white font-bold text-[15px] sm:text-[17px] hover:text-blue-400 transition leading-none block truncate">

              <%= post.author.name %>

            </a>

          </div>





          <!-- DATE -->
          <div class="text-[10px] sm:text-xs text-zinc-500 whitespace-nowrap pt-0.5">
            <%= new Date(post.createdAt).toLocaleString() %>
          </div>

        </div>





        <!-- CONTENT + ACTIONS -->
        <div class="flex items-center justify-between gap-4 mt-2">

          <!-- POST -->
          <div class="flex-1 min-w-0">

            <p class="text-lg sm:text-[20px] text-zinc-200 leading-6 sm:leading-7 break-words">
              <%= post.content %>
            </p>

          </div>





          <!-- ACTIONS -->
          <div class="flex items-center gap-1 sm:gap-2 shrink-0">

            <!-- LIKE -->
            <form action="/posts/<%= post._id %>/like" method="POST">

              <% const liked = (post.likes || []).map(l => String(l)).includes(String(user._id)); %>

              <button
                class="flex items-center gap-1 px-2 py-1 rounded-xl hover:bg-zinc-800/60 transition-all duration-300">

                <!-- heart -->
                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-[18px] h-[18px] sm:w-5 sm:h-5 <%= liked ? 'text-pink-500 fill-pink-500' : 'text-zinc-400' %>"
                  fill="<%= liked ? 'currentColor' : 'none' %>"
                  viewBox="0 0 24 24"
                  stroke="currentColor">

                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 21s-6.7-4.8-9.4-9C1 10 1.5 6.5 4.2 5A5.4 5.4 0 0 1 12 6a5.4 5.4 0 0 1 7.8-1c2.7 1.6 3.2 5 1.6 7C18.7 16.1 12 21 12 21z"
                  />

                </svg>

                <span class="text-xs sm:text-sm text-zinc-300 font-medium">
                  <%= post.likes.length %>
                </span>

              </button>

            </form>





            <% if (String(post.author._id) === String(user._id)) { %>

              <!-- EDIT -->
              <a
                href="/posts/<%= post._id %>/edit"
                class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl flex items-center justify-center text-yellow-400 hover:bg-yellow-500/10 transition-all duration-300">

                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 sm:w-5 sm:h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor">

                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16.862 4.487l1.651-1.652a2.1 2.1 0 113 3L11.25 16.1l-4 1 1-4L16.862 4.487z"
                  />

                </svg>

              </a>





              <!-- DELETE -->
              <form action="/posts/<%= post._id %>/delete" method="POST">

                <button
                  class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl flex items-center justify-center text-red-400 hover:bg-red-500/10 transition-all duration-300">

                  <svg xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 sm:w-5 sm:h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor">

                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 7h12m-1 0l-.867 12.1A2 2 0 0114.1 21H9.9a2 2 0 01-2-1.9L7 7m5-4h-1a2 2 0 00-2 2v2h6V5a2 2 0 00-2-2z"
                    />

                  </svg>

                </button>

              </form>

            <% } %>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>