<div class="group relative w-full">

  <div class="absolute inset-0 rounded-[30px] bg-gradient-to-r from-blue-500/10 via-indigo-500/5 to-pink-500/10 blur-2xl opacity-0 group-hover:opacity-100 transition duration-500"></div>

  <div class="relative bg-transparent rounded-[28px] px-4 py-4 sm:px-5 sm:py-5 transition-all duration-300 backdrop-blur-xl">

    <div class="flex gap-3 sm:gap-4">

      <a href="/user/<%= post.author._id %>" class="shrink-0">
        <img src="<%= post.author.profile || '/profile/defaultProfile.png' %>" alt="author"
          class="w-12 h-12 sm:w-14 sm:h-14 rounded-2xl object-cover border border-zinc-700 hover:border-blue-500 transition-all duration-300"/>
      </a>

      <div class="flex-1 min-w-0">

        <div class="flex items-start justify-between gap-3">

          <div class="min-w-0">
            <a href="/user/<%= post.author._id %>"
              class="text-white font-bold text-[15px] sm:text-[17px] hover:text-blue-400 transition leading-none block truncate">
              <%= post.author.name %>
            </a>
          </div>

          <div class="text-[10px] sm:text-xs text-zinc-500 whitespace-nowrap pt-0.5">
            <%= new Date(post.createdAt).toLocaleString() %>
          </div>

        </div>

        <div class="flex justify-between items-start gap-4 mt-3">

          <div class="flex-1 min-w-0">

            <p id="content-<%= post._id %>"
              class="text-[15px] sm:text-[16px] text-zinc-200 leading-7 break-words">
              <%= post.content %>
            </p>

            <% if (String(post.author._id) === String(user._id)) { %>

              <form id="edit-form-<%= post._id %>" action="/posts/<%= post._id %>/edit"
                method="POST" class="hidden mt-1">

                <textarea name="content" rows="3"
                  class="w-full bg-zinc-900/80 border border-zinc-700 rounded-2xl px-4 py-3 text-[15px] text-white outline-none resize-none focus:border-blue-500 transition-all duration-300"><%= post.content %></textarea>

                <div class="flex items-center gap-2 mt-3">

                  <button
                    class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 transition text-sm font-medium">
                    Save
                  </button>

                  <button type="button" onclick="cancelEdit('<%= post._id %>')"
                    class="px-4 py-2 rounded-xl bg-zinc-800 hover:bg-zinc-700 transition text-sm font-medium">
                    Cancel
                  </button>

                </div>

              </form>

            <% } %>

          </div>

          <div class="flex items-center gap-1 shrink-0 self-center">

            <form action="/posts/<%= post._id %>/like" method="POST">

              <% const liked = (post.likes || []).map(l => String(l)).includes(String(user._id)); %>

              <button
                class="flex items-center gap-1 px-1.5 py-1 rounded-lg hover:bg-zinc-800/60 transition-all duration-300">

                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-[18px] h-[18px] sm:w-5 sm:h-5 <%= liked ? 'text-pink-500 fill-pink-500' : 'text-zinc-400' %>"
                  fill="<%= liked ? 'currentColor' : 'none' %>"
                  viewBox="0 0 24 24" stroke="currentColor">

                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 21s-6.7-4.8-9.4-9C1 10 1.5 6.5 4.2 5A5.4 5.4 0 0 1 12 6a5.4 5.4 0 0 1 7.8-1c2.7 1.6 3.2 5 1.6 7C18.7 16.1 12 21 12 21z"/>
                </svg>

                <span class="text-xs sm:text-sm text-zinc-300 font-medium">
                  <%= post.likes.length %>
                </span>

              </button>

            </form>

            <% if (String(post.author._id) === String(user._id)) { %>

              <button type="button" onclick="enableEdit('<%= post._id %>')"
                class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg flex items-center justify-center text-yellow-400 hover:bg-yellow-500/10 transition-all duration-300">

                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor">

                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16.862 4.487l1.651-1.652a2.1 2.1 0 113 3L11.25 16.1l-4 1 1-4L16.862 4.487z"/>
                </svg>

              </button>

              <form action="/posts/<%= post._id %>/delete" method="POST">

                <button
                  class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg flex items-center justify-center text-red-400 hover:bg-red-500/10 transition-all duration-300">

                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5"
                    fill="none" viewBox="0 0 24 24" stroke="currentColor">

                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M6 7h12m-1 0l-.867 12.1A2 2 0 0114.1 21H9.9a2 2 0 01-2-1.9L7 7m5-4h-1a2 2 0 00-2 2v2h6V5a2 2 0 00-2-2z"/>
                  </svg>

                </button>

              </form>

            <% } %>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>

<script>
  function enableEdit(id) {
    document.getElementById(`content-${id}`).classList.add("hidden");
    document.getElementById(`edit-form-${id}`).classList.remove("hidden");
  }

  function cancelEdit(id) {
    document.getElementById(`content-${id}`).classList.remove("hidden");
    document.getElementById(`edit-form-${id}`).classList.add("hidden");
  }
</script>